## Shared Properties (Reusing Standards)
:timestamp a owl:DatatypeProperty ;
    rdfs:label "timestamp"@en ;
    rdfs:comment "Timestamp of the entity (creation, modification, execution)."@en ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:dateTime ;
    rdfs:subPropertyOf schema:dateModified ;
    rdfs:isDefinedBy : .

:version a owl:DatatypeProperty ;
    rdfs:label "version"@en ;
    rdfs:comment "Version of the entity."@en ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:version ;
    rdfs:isDefinedBy : .

:status a owl:DatatypeProperty ;
    rdfs:label "status"@en ;
    rdfs:comment "Status of the entity (e.g., active, retracted, pending, completed)."@en ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy : .